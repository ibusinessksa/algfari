# Used when you pass --env=testing (e.g. php artisan migrate:fresh --env=testing).
# Without this file, Laravel keeps loading .env and hits family_tribe_app instead.

APP_NAME="Family Tribe App"
APP_ENV=testing
APP_KEY=base64:eCZqu1BG0w/p4i9KszZl071C56SeHe0Y6rig9QloZH0=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA
APP_AVAILABLE_LOCALES=ar,en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=family_tribe_test
DB_USERNAME=root
DB_PASSWORD=1234

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=array

MAIL_MAILER=array
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

PASSWORD_RESET_SESSION_TTL=15

OTP_DRIVER=
